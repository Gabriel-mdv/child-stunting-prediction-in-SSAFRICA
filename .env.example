# ── AFRICA'S TALKING SMS CONFIGURATION ───────────────────────────────────────
#
# Create a free account at https://account.africastalking.com
# Then copy this file to .env and fill in your credentials.
#
# TESTING (sandbox):
#   1. Set AT_USERNAME=sandbox and use your sandbox API key
#   2. Open https://simulator.africastalking.com and add a test phone number
#   3. Trigger a HIGH-risk prediction — the SMS appears in the simulator inbox
#
# PRODUCTION:
#   Set AT_USERNAME to your registered AT username (not 'sandbox')
#   Alphanumeric sender IDs (e.g. CHW_TOOL) must be pre-registered per country.
#   Use a numeric shortcode for testing without pre-registration.

AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key_here

# Optional: alphanumeric sender ID shown on the recipient's phone.
# Leave blank to use the default AT shortcode.
AT_SENDER_ID= 

# Default supervisor phone to send HIGH-risk alerts to.
# The CHW can also enter/override this in the web form.
# International format required, e.g.:
#   Nigeria:   +2348012345678
#   Rwanda:    +250788123456
#   Ethiopia:  +251911234567
SUPERVISOR_PHONE= +250785813700
